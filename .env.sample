# Neon DB pooled connection (used by Prisma at runtime via @prisma/adapter-neon)
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require"

# Neon DB direct connection (used by Prisma for migrations)
DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<dbname>?sslmode=require"

# Redis connection (used by BullMQ for the scan job queue)
REDIS_URL="redis://localhost:6379"

# Trivy server URL — start with: trivy server --listen 0.0.0.0:4954
TRIVY_SERVER_URL="http://localhost:4954"

# HTTP port (optional, defaults to 3000)
PORT=3000

# Secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET="ENTER JWT-SECRET"

# Allowed origin for the frontend (use * for any in dev)
FRONTEND_URL="http://localhost:3001"
