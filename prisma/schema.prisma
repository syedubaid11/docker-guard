generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScanStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model Scan {
  id              String          @id @default(uuid())
  image           String
  status          ScanStatus      @default(PENDING)
  jobId           String?         @unique
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  userId          Int?
  user            users?          @relation(fields: [userId], references: [id])

  vulnerabilities Vulnerability[]

  @@index([userId])
  @@index([status])
}

model Vulnerability {
  id               String  @id @default(uuid())
  scanId           String
  scan             Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  vulnerabilityId  String
  pkgName          String
  installedVersion String
  fixedVersion     String?
  severity         String
  title            String?
  description      String?

  @@index([scanId])
  @@index([severity])
}

model users {
  id           Int     @id @default(autoincrement())
  name         String?
  email        String? @unique
  password     String?
  date_created String?

  scans        Scan[]
}
